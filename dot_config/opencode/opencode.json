{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
    "edit": {
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny"
    },
    "bash": {
      "rm *credentials*": "deny",
      "rm *.env*": "deny"
    }
  },
  "model": "opencode-go/deepseek-v4-flash",
  "default_agent": "build",
  "instructions": [
    "./prompts/general-guideline.md",
  ],
  "experimental": {
    "disable_paste_summary": true,
  },
  "agent": {
    "build": {
      "description": "Primary coding agent that delegates command execution to @executor",
      "model": "opencode-go/kimi-k2.6",
      "permission": {
        "bash": "deny"
      },
      "prompt": "{file:./prompts/coding-guideline.md}"
    },
    "plan": {
      "description": "Structured implementation planning",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./prompts/plan-guideline.md}"
    },
    "explore": {
      "description": "Fast codebase exploration",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
      "prompt": "{file:./prompts/explore-guideline.md}"
    },
    "reviewer": {
      "description": "Automated review agent",
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max",
      "mode": "all",
      "prompt": "Use code-review skill"
    },
    "executor": {
      "description": "Default execution subagent for bash commands, tests, builds, and validation",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent",
      "prompt": "{file:./prompts/executor-guideline.md}"
    },
  },
  "plugin": []
}
