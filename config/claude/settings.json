{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(tmux list-sessions:*)",
      "Bash(tmux list-windows:*)",
      "Bash(tmux list-panes:*)",
      "Bash(tmux display-message:*)",
      "Bash(tmux capture-pane:*)",
      "Bash(tmux show-options:*)",
      "Bash(tmux show-environment:*)",
      "Bash(tmux has-session:*)",
      "Bash(tmux send-keys:*)",
      "Bash(tmux select-pane:*)",
      "Bash(tmux split-window:*)",
      "Bash(tmux new-window:*)",
      "Bash(tmux rename-window:*)"
    ],
    "deny": [
      "Bash(tmux kill-server:*)",
      "Bash(tmux kill-session:*)",
      "Bash(tmux kill-window:*)",
      "Bash(tmux kill-pane:*)",
      "Bash(tmux source-file:*)"
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "voice-writer@jtmthf-skills": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "ast-grep@ast-grep-marketplace": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "jtmthf-skills": {
      "source": {
        "source": "github",
        "repo": "jtmthf/skills"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "hooksmith": {
      "source": {
        "source": "github",
        "repo": "jtmthf/hooksmith"
      }
    }
  },
  "effortLevel": "medium",
  "teammateMode": "tmux",
  "mcpServers": {
    "ast-grep": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp",
        "ast-grep-server"
      ]
    }
  }
}
