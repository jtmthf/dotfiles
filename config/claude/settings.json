{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(eza:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(bat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(dust:*)",
      "Bash(duf:*)",
      "Bash(df:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(grepai:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(choose:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(uname:*)",
      "Bash(sw_vers:*)",
      "Bash(pwd:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(date:*)",
      "Bash(ps:*)",
      "Bash(procs:*)",
      "Bash(tokei:*)",
      "Bash(tldr:*)",
      "Bash(glow:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git blame:*)",
      "Bash(git stash list:*)",
      "Bash(git tag:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(git config --list:*)",
      "Bash(git config --get:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh auth status:*)",
      "Bash(mise list:*)",
      "Bash(mise current:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew deps:*)",
      "Bash(tmux list-sessions:*)",
      "Bash(tmux list-windows:*)",
      "Bash(tmux list-panes:*)",
      "Bash(tmux display-message:*)",
      "Bash(tmux capture-pane:*)",
      "Bash(tmux show-options:*)",
      "Bash(tmux show-environment:*)",
      "Bash(tmux has-session:*)",
      "Bash(tmux send-keys:*)",
      "Bash(tmux select-pane:*)",
      "Bash(tmux split-window:*)",
      "Bash(tmux new-window:*)",
      "Bash(tmux rename-window:*)",
      "Bash(crwl:*)",
      "Bash(sg:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "mcp__serena__find_symbol",
      "mcp__serena__find_referencing_symbols",
      "mcp__serena__find_file",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__search_for_pattern",
      "mcp__serena__list_dir",
      "mcp__serena__read_file",
      "mcp__serena__list_memories",
      "mcp__serena__read_memory",
      "mcp__serena__check_onboarding_performed",
      "mcp__serena__initial_instructions",
      "mcp__serena__activate_project"
    ],
    "deny": [
      "Bash(tmux kill-server:*)",
      "Bash(tmux kill-session:*)",
      "Bash(tmux kill-window:*)",
      "Bash(tmux kill-pane:*)",
      "Bash(tmux source-file:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "voice-writer@jtmthf-skills": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "ast-grep@ast-grep-marketplace": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "jtmthf-skills": {
      "source": {
        "source": "github",
        "repo": "jtmthf/skills"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "hooksmith": {
      "source": {
        "source": "github",
        "repo": "jtmthf/hooksmith"
      }
    }
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0,
    "refreshInterval": 10
  },
  "effortLevel": "medium",
  "teammateMode": "tmux",
  "mcpServers": {
    "ast-grep": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp",
        "ast-grep-server"
      ]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd"
      ]
    }
  }
}
